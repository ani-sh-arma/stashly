# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=*******************

NEXT_PUBLIC_CONVEX_URL=**************************

NEXT_PUBLIC_CONVEX_SITE_URL=**************************


# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk routes (keep as-is)
